{
  "name": "MOMIT - רשת חברתית לאמהות בישראל",
  "short_name": "MOMIT",
  "description": "MOMIT - כי רק אמא מבינה אמא. הקהילה של אמהות ישראל - מקום בטוח לשתף, להתייעץ ולקבל תמיכה.",
  "start_url": "/?source=pwa",
  "display": "standalone",
  "display_override": [
    "standalone",
    "fullscreen",
    "minimal-ui",
    "browser"
  ],
  "background_color": "#FCFAF9",
  "theme_color": "#D4A1AC",
  "orientation": "portrait-primary",
  "prefer_related_applications": false,
  "categories": [
    "social",
    "lifestyle",
    "health",
    "parenting"
  ],
  "lang": "he",
  "dir": "rtl",
  "scope": "/",
  "id": "/",
  "shortcuts": [
    {
      "name": "הפיד",
      "short_name": "פיד",
      "description": "צפייה בפוסטים ובעדכונים מהקהילה",
      "url": "/#/feed",
      "icons": [
        {
          "src": "icons/Icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "הודעות",
      "short_name": "צ'אט",
      "description": "צ'אט והודעות עם אמהות אחרות",
      "url": "/#/chat",
      "icons": [
        {
          "src": "icons/Icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "פרופיל",
      "short_name": "אני",
      "description": "הפרופיל וההגדרות שלי",
      "url": "/#/profile",
      "icons": [
        {
          "src": "icons/Icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "icons": [
    {
      "src": "icons/Icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/Icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/Icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/Icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.momconnect.social",
      "id": "com.momconnect.social"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/momit/",
      "id": "com.momconnect.social"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+momit",
      "url": "/%s"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "video/*"]
        }
      ]
    }
  }
}
