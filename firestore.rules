rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    function isModerator() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // App configuration - public read, admin write
    match /app_config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Admin config - non-sensitive docs readable by authenticated users, api_keys admin only
    match /admin_config/{doc} {
      allow read: if doc != 'api_keys' && isAuthenticated();
      allow write: if isAdmin();
    }
    match /admin_config/api_keys {
      allow read, write: if isAdmin();
    }
    
    // Feature flags - public read, admin write
    match /feature_flags/{flag} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // UI configuration - public read, admin write
    match /ui_config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Dynamic sections - public read, admin full access
    match /dynamic_sections/{section} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Content management - public read, admin full access
    match /content_management/{content} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Users - authenticated read, owner or admin write
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId &&
        request.resource.data.keys().hasAll(['email', 'fullName']) &&
        request.resource.data.email is string &&
        request.resource.data.fullName is string;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // User subcollections
    match /users/{userId}/{subcollection}/{doc} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }
    
    // Experts - public read, admin write
    match /experts/{expertId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Events - public read, admin write
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || 
        (isAuthenticated() && resource.data.creatorId == request.auth.uid);
    }
    
    // Marketplace - public read, authenticated write own items
    match /marketplace/{itemId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    
    // Tips - public read, admin write
    match /tips/{tipId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Posts - public read, authenticated write
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && 
        (resource.data.authorId == request.auth.uid || isAdmin());
    }
    
    // Reports - authenticated create, admin read/update
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin() || isModerator();
    }
    
    // Media library - public read, admin write
    match /media_library/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // User roles (RBAC) - admin only write, authenticated read own
    match /user_roles/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAdmin(); // SECURITY: Only admins can modify roles
    }

    // Activity log - admin read/create, authenticated create own entries
    match /activity_log/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
    
    // Push notifications - authenticated read own, admin write all
    match /push_notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }
    
    // Error logs - admin read, authenticated create
    match /error_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.size() < 10240; // Limit document size to 10KB
    }
    
    // Analytics - admin only
    match /analytics/{doc} {
      allow read, write: if isAdmin();
    }
    
    // Audit logs - admin only
    match /admin_audit_log/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
    
    // Direct Messages - participants only
    match /directMessages/{convId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();
    }

    match /directMessages/{convId}/messages/{msgId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/directMessages/$(convId)).data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/directMessages/$(convId)).data.participants;
      allow delete: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid || isAdmin());
    }

    // Chat Groups - authenticated access
    match /chatGroups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (resource.data.creatorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /chatGroups/{groupId}/messages/{msgId} {
      allow read: if isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/chatGroups/$(groupId)).data.members;
      allow create: if isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/chatGroups/$(groupId)).data.members;
      allow delete: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid || isAdmin());
    }

    // SOS Alerts - authenticated create own, admin/owner read
    match /sos_alerts/{alertId} {
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Mood Entries - owner or admin
    match /mood_entries/{entryId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Bookings - owner and admin
    match /bookings/{bookingId} {
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Tracking data - owner or admin only
    match /tracking/{userId}/{subcollection}/{doc} {
      allow read, write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }
    
    // Notifications - authenticated create own, owner read, admin full access
    // Flat collection: each doc has a 'userId' field
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId is string;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Admin notifications - admin read/write, authenticated create
    match /admin_notifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // FCM tokens - owner write own tokens, admin read
    match /fcm_tokens/{tokenId} {
      allow read: if isAdmin();
      allow create, update: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Analytics events - authenticated create, admin read
    match /analytics_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
