# ════════════════════════════════════════════════════════════════
# MOMIT - Environment Configuration Template
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Admin Configuration - admin emails (comma-separated)
ADMIN_EMAILS=your-admin@email.com

# JWT Secrets for token generation (min 32 chars each)
JWT_ACCESS_SECRET=your-access-secret-min-32-characters-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-here

# Gemini AI API Key (for MomBot)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Mailjet API Keys (for email notifications)
# Get from: https://app.mailjet.com/account/apikeys
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_SECRET_KEY=your-mailjet-secret-key

# Email Configuration
EMAIL_FROM=noreply@momit.co.il
EMAIL_FROM_NAME=MOMIT System

# Cloudflare Pages (for deployment)
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_PAGES_PROJECT_NAME=momit
