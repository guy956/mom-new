# Cloudflare Pages Environment Variables
# Copy this file to .env and fill in your values

# Cloudflare API Token (from dash.cloudflare.com/profile/api-tokens)
CLOUDFLARE_API_TOKEN=your_api_token_here

# Cloudflare Account ID (from Cloudflare Dashboard right sidebar)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Cloudflare Pages Project Name (default: momit)
CLOUDFLARE_PAGES_PROJECT_NAME=momit
