# Cloudflare Pages Headers Configuration
# https://developers.cloudflare.com/pages/configuration/headers/

# Global Security Headers for all pages
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(self), geolocation=(self), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), clipboard-read=(self), clipboard-write=(self), display-capture=(self), fullscreen=(self), picture-in-picture=(self), publickey-credentials-get=(self), publickey-credentials-create=(self), web-share=(self)
  Cross-Origin-Embedder-Policy: credentialless
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Sitemap - 1 day cache
/sitemap.xml
  Cache-Control: public, max-age=86400
  Content-Type: application/xml

# Robots.txt - 1 day cache
/robots.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain

# Browser config - 1 week cache
/browserconfig.xml
  Cache-Control: public, max-age=604800

# OpenSearch - 1 week cache
/opensearch.xml
  Cache-Control: public, max-age=604800

# Cache static assets - 1 year (immutable)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Cache icon assets - 1 year
/icons/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Cache fonts if any - 1 year
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Service worker - no cache (must revalidate)
/flutter_service_worker.js
  Cache-Control: public, max-age=0, must-revalidate

/flutter_service_worker.js?v=*
  Cache-Control: public, max-age=0, must-revalidate

# Main app files - shorter cache (1 hour)
/main.dart.js
  Cache-Control: public, max-age=3600
  Vary: Accept-Encoding

/main.dart.js?v=*
  Cache-Control: public, max-age=3600
  Vary: Accept-Encoding

# Flutter bootstrap - no cache
/flutter_bootstrap.js
  Cache-Control: public, max-age=0, must-revalidate

# HTML entry point - no cache (SPA)
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Manifest and config files - short cache
/manifest.json
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *

/favicon.svg
  Cache-Control: public, max-age=86400

/favicon.png
  Cache-Control: public, max-age=86400

# JavaScript files - 1 hour cache
/*.js
  Cache-Control: public, max-age=3600
  Vary: Accept-Encoding

# Legal pages - 1 day cache (may change)
/privacy
  Cache-Control: public, max-age=86400
  X-Frame-Options: SAMEORIGIN

/privacy.html
  Cache-Control: public, max-age=86400

/terms
  Cache-Control: public, max-age=86400
  X-Frame-Options: SAMEORIGIN

/terms.html
  Cache-Control: public, max-age=86400

# WebAssembly files - 1 year cache
/*.wasm
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/wasm

# JSON data files - 1 hour cache
/*.json
  Cache-Control: public, max-age=3600

# Images - 1 week cache
/*.png
  Cache-Control: public, max-age=604800

/*.jpg
  Cache-Control: public, max-age=604800

/*.jpeg
  Cache-Control: public, max-age=604800

/*.gif
  Cache-Control: public, max-age=604800

/*.webp
  Cache-Control: public, max-age=604800

/*.svg
  Cache-Control: public, max-age=604800
