# MOMIT API Environment Variables
# Copy this file to .env and fill in your secure values

# Server Configuration
NODE_ENV=production
PORT=3000

# CORS Configuration
ALLOWED_ORIGINS=https://momit.app,https://www.momit.app

# JWT Secrets - Generate strong secrets using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_super_secret_access_key_min_64_chars_long_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_long_here

# Cookie Configuration
COOKIE_DOMAIN=momit.app

# Database (add your database configuration)
# DATABASE_URL=
# REDIS_URL=

# Email Service (for password reset, etc.)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
